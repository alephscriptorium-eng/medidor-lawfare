{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medidor-lawfare.dev/schema/catalog.json",
  "title": "Catálogo prensa",
  "type": "object",
  "required": ["version", "mediciones_publicas", "casos"],
  "properties": {
    "version": { "type": "string" },
    "mediciones_publicas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "caso_id", "intensidad", "lectura"],
        "properties": {
          "id": { "type": "string" },
          "caso_id": { "type": "string" },
          "intensidad": { "type": "number" },
          "lectura": { "type": "string" },
          "destacada": { "type": "boolean" },
          "url_prensa": { "type": "string" }
        }
      }
    },
    "casos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "etiqueta"],
        "properties": {
          "id": { "type": "string" },
          "etiqueta": { "type": "string" },
          "ejemplo": { "type": "boolean" }
        }
      }
    }
  }
}
