{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medidor-lawfare.dev/schema/medicion/v1",
  "title": "Medicion",
  "type": "object",
  "required": ["id", "ejes", "intensidad", "lectura"],
  "properties": {
    "id": { "type": "string", "pattern": "^M\\d+$" },
    "buffers_activos": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ejes": {
      "type": "object",
      "required": ["integridad", "sincronia", "ventana", "impacto", "vector"],
      "properties": {
        "integridad": { "type": "number" },
        "sincronia": { "type": "number" },
        "ventana": { "type": "number" },
        "impacto": { "type": "number" },
        "vector": { "type": "number" }
      }
    },
    "intensidad": { "type": "number", "minimum": 0, "maximum": 10 },
    "lectura": { "type": "string" }
  }
}
